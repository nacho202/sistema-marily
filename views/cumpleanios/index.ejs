<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <title>Cumpleaños - El Rincon de Doña Rosa</title>
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/navbar') %>
    
    <main class="container">
        <h2><i class="fas fa-birthday-cake"></i> Próximos Cumpleaños (10 días)</h2>
        
        <% if (clientes && clientes.length > 0) { %>
            <table class="table">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th>Días restantes</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    <% clientes.forEach(cliente => { %>
                        <tr>
                            <td><strong><%= cliente.nombre %></strong></td>
                            <td>
                                <% 
                                const meses = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 
                                              'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
                                let diaMostrar, mesMostrar;
                                if (cliente.dia_cumpleanios && cliente.mes_cumpleanios) {
                                    diaMostrar = cliente.dia_cumpleanios;
                                    mesMostrar = cliente.mes_cumpleanios;
                                } else if (cliente.fecha_cumpleanios) {
                                    const partes = cliente.fecha_cumpleanios.split('-');
                                    diaMostrar = parseInt(partes[2]);
                                    mesMostrar = parseInt(partes[1]);
                                } else if (cliente.fecha_nacimiento) {
                                    const partes = cliente.fecha_nacimiento.split('-');
                                    diaMostrar = parseInt(partes[2]);
                                    mesMostrar = parseInt(partes[1]);
                                }
                                %>
                                <%= diaMostrar ? diaMostrar : '-' %> <%= mesMostrar ? ('de ' + meses[mesMostrar - 1]) : '' %>
                            </td>
                            <td><%= typeof cliente.dias_restantes === 'number' ? cliente.dias_restantes : '-' %></td>
                            <td><%= cliente.telefono || '-' %></td>
                            <td><%= cliente.email || '-' %></td>
                            <td>
                                <a href="/clientes/<%= cliente.id %>" class="btn btn-small btn-primary" title="Ver Cliente"><i class="fas fa-eye"></i></a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <p class="no-data">No hay clientes con fecha de nacimiento registrada.</p>
        <% } %>
    </main>
    
    <%- include('../partials/help-button') %>
    <%- include('../partials/help-modal') %>
    
    <script src="/js/main.js?v=<%= assetVersion || 'dev' %>"></script>
    <script src="/js/help.js?v=<%= assetVersion || 'dev' %>"></script>
</body>
</html>

