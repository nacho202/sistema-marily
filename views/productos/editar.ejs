<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <title>Editar Producto - El Rincon de Doña Rosa</title>
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/navbar') %>
    
    <main class="container">
        <h2><i class="fas fa-box"></i> Editar Producto</h2>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>
        
        <form method="POST" action="/productos/<%= producto.id %>/editar" class="form" enctype="multipart/form-data">
            <div class="form-group">
                <label for="nombre">Nombre *</label>
                <input type="text" id="nombre" name="nombre" required value="<%= producto.nombre %>">
            </div>
            
            <div class="form-group">
                <label for="descripcion">Descripción</label>
                <textarea id="descripcion" name="descripcion" rows="3"><%= producto.descripcion || '' %></textarea>
            </div>
            
            <div class="form-group">
                <label for="precio">Precio venta *</label>
                <input type="number" id="precio" name="precio" step="0.01" min="0" required value="<%= producto.precio %>">
            </div>
            
            <div class="form-group">
                <label>Stock Actual</label>
                <p class="info-text">Stock actual: <strong><%= producto.stock_actual %></strong> (usar "Sumar Stock" desde el listado para actualizar)</p>
            </div>
            
            <div class="form-group">
                <label>Imágenes</label>

                <% if (imagenes && imagenes.length > 0) { %>
                    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 0.75rem; margin-bottom: 0.75rem;">
                        <% imagenes.forEach(img => { %>
                            <div style="border: 1px solid #d1cfff; border-radius: 8px; padding: 0.5rem; background: #f8f7ff;">
                                <a href="<%= img.url %>" target="_blank" rel="noreferrer">
                                    <img src="<%= img.url %>" alt="Imagen producto" style="width: 100%; height: 110px; object-fit: cover; border-radius: 6px;">
                                </a>
                                <button
                                    type="submit"
                                    class="btn btn-small btn-danger"
                                    style="width:100%; margin-top: 0.5rem;"
                                    formaction="/productos/<%= producto.id %>/imagenes/<%= img.id %>/eliminar"
                                    formmethod="POST"
                                    onclick="return confirm('¿Eliminar esta imagen?');"
                                >
                                    <i class="fas fa-trash"></i> Eliminar
                                </button>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <p class="no-data" style="margin: 0 0 0.75rem;">Este producto no tiene imágenes.</p>
                <% } %>

                <div data-producto-imagenes>
                    <div data-imagen-dropzone style="padding: 1rem; border: 1px dashed #d1cfff; border-radius: 8px; background: #f8f7ff;">
                        <div style="display:flex; gap:0.75rem; align-items:center; flex-wrap:wrap;">
                            <input type="file" name="imagenes_files" accept="image/*" multiple>
                            <input type="text" data-imagen-url-input placeholder="Pegá un link de imagen (https://...)" style="flex: 1; min-width: 220px;">
                            <button type="button" class="btn btn-small btn-secondary" data-imagen-add-url>Agregar link</button>
                        </div>
                        <p style="margin: 0.75rem 0 0; color:#666; font-size: 0.9rem;">
                            Tip: podés <strong>arrastrar y soltar</strong> una imagen o un link acá.
                        </p>
                    </div>
                    <div data-imagen-list style="margin-top: 0.75rem;"></div>
                </div>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Actualizar Producto</button>
                <a href="/productos" class="btn btn-secondary"><i class="fas fa-times"></i> Cancelar</a>
            </div>
        </form>
    </main>
    
    <%- include('../partials/help-button') %>
    <%- include('../partials/help-modal') %>
    <%- include('../partials/image-cropper-modal') %>
    
    <script src="/js/main.js?v=<%= assetVersion || 'dev' %>"></script>
    <link rel="stylesheet" href="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.css">
    <script src="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.js"></script>
    <script src="/js/image-cropper.js?v=<%= assetVersion || 'dev' %>"></script>
    <script src="/js/producto-imagenes.js?v=<%= assetVersion || 'dev' %>"></script>
    <script src="/js/help.js?v=<%= assetVersion || 'dev' %>"></script>
</body>
</html>

