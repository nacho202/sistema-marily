<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <title>Nuevo Producto - El Rincon de Doña Rosa</title>
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/navbar') %>
    
    <main class="container">
        <h2><i class="fas fa-box"></i> Nuevo Producto</h2>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>
        
        <form method="POST" action="/productos" class="form" enctype="multipart/form-data">
            <div class="form-group">
                <label for="nombre">Nombre *</label>
                <input type="text" id="nombre" name="nombre" required value="<%= typeof producto !== 'undefined' ? producto.nombre : '' %>">
            </div>
            
            <div class="form-group">
                <label for="descripcion">Descripción</label>
                <textarea id="descripcion" name="descripcion" rows="3"><%= typeof producto !== 'undefined' ? producto.descripcion || '' : '' %></textarea>
            </div>
            
            <div class="form-group">
                <label for="precio">Precio *</label>
                <input type="number" id="precio" name="precio" step="0.01" min="0" required value="<%= typeof producto !== 'undefined' ? producto.precio : '' %>">
            </div>
            
            <div class="form-group">
                <label for="stock_actual">Stock Inicial</label>
                <input type="number" id="stock_actual" name="stock_actual" min="0" value="<%= typeof producto !== 'undefined' ? producto.stock_actual : '0' %>">
            </div>
            
            <div class="form-group">
                <label>Imágenes</label>
                <div data-producto-imagenes>
                    <div data-imagen-dropzone style="padding: 1rem; border: 1px dashed #d1cfff; border-radius: 8px; background: #f8f7ff;">
                        <div style="display:flex; gap:0.75rem; align-items:center; flex-wrap:wrap;">
                            <input type="file" name="imagenes_files" accept="image/*" multiple>
                            <input type="text" data-imagen-url-input placeholder="Pegá un link de imagen (https://...)" style="flex: 1; min-width: 220px;">
                            <button type="button" class="btn btn-small btn-secondary" data-imagen-add-url>Agregar link</button>
                        </div>
                        <p style="margin: 0.75rem 0 0; color:#666; font-size: 0.9rem;">
                            Tip: podés <strong>arrastrar y soltar</strong> una imagen o un link (por ejemplo desde Google) acá.
                        </p>
                    </div>
                    <div data-imagen-list style="margin-top: 0.75rem;"></div>
                </div>
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Crear Producto</button>
                <a href="/productos" class="btn btn-secondary"><i class="fas fa-times"></i> Cancelar</a>
            </div>
        </form>
    </main>
    
    <%- include('../partials/help-button') %>
    <%- include('../partials/help-modal') %>
    <%- include('../partials/image-cropper-modal') %>
    
    <script src="/js/main.js?v=<%= assetVersion || 'dev' %>"></script>
    <link rel="stylesheet" href="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.css">
    <script src="https://unpkg.com/cropperjs@1.6.2/dist/cropper.min.js"></script>
    <script src="/js/image-cropper.js?v=<%= assetVersion || 'dev' %>"></script>
    <script src="/js/producto-imagenes.js?v=<%= assetVersion || 'dev' %>"></script>
    <script src="/js/help.js?v=<%= assetVersion || 'dev' %>"></script>
</body>
</html>

