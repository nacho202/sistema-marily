<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <title>Comparar Períodos - El Rincon de Doña Rosa</title>
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/navbar') %>
    
    <main class="container">
        <div class="page-header">
            <h2><i class="fas fa-exchange-alt"></i> Comparar Períodos</h2>
            <a href="/estadisticas" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Volver a Estadísticas
            </a>
        </div>
        
        <form method="GET" action="/estadisticas/comparar" class="search-form" style="margin-bottom: 2rem;">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div>
                    <h4>Período 1</h4>
                    <label>Desde:</label>
                    <input type="date" name="fecha_inicio1" value="<%= fechaInicio1 || '' %>" required>
                    <label>Hasta:</label>
                    <input type="date" name="fecha_fin1" value="<%= fechaFin1 || '' %>" required>
                </div>
                <div>
                    <h4>Período 2</h4>
                    <label>Desde:</label>
                    <input type="date" name="fecha_inicio2" value="<%= fechaInicio2 || '' %>" required>
                    <label>Hasta:</label>
                    <input type="date" name="fecha_fin2" value="<%= fechaFin2 || '' %>" required>
                </div>
            </div>
            <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Comparar</button>
        </form>
        
        <% if (comparacion) { %>
            <div class="stats-grid" style="grid-template-columns: repeat(3, 1fr); margin-bottom: 2rem;">
                <div class="stat-card">
                    <h3>Período 1</h3>
                    <p class="stat-value">$<%= parseFloat(comparacion.periodo1.totalVendido).toFixed(2) %></p>
                    <p style="font-size: 0.9rem; color: #666;">
                        <%= comparacion.periodo1.cantidadVentas %> ventas<br>
                        <%= comparacion.periodo1.cantidadProductos %> productos
                    </p>
                </div>
                
                <div class="stat-card">
                    <h3>Período 2</h3>
                    <p class="stat-value">$<%= parseFloat(comparacion.periodo2.totalVendido).toFixed(2) %></p>
                    <p style="font-size: 0.9rem; color: #666;">
                        <%= comparacion.periodo2.cantidadVentas %> ventas<br>
                        <%= comparacion.periodo2.cantidadProductos %> productos
                    </p>
                </div>
                
                <div class="stat-card" style="<%= comparacion.diferencia.ventas >= 0 ? 'border-color: #10b981;' : 'border-color: #ef4444;' %>">
                    <h3>Diferencia</h3>
                    <p class="stat-value" style="color: <%= comparacion.diferencia.ventas >= 0 ? '#10b981' : '#ef4444' %>;">
                        <%= comparacion.diferencia.ventas >= 0 ? '+' : '' %>$<%= parseFloat(comparacion.diferencia.ventas).toFixed(2) %>
                    </p>
                    <p style="font-size: 0.9rem; color: #666;">
                        <%= comparacion.diferencia.porcentaje >= 0 ? '+' : '' %><%= comparacion.diferencia.porcentaje %>%<br>
                        <%= comparacion.diferencia.cantidadVentas >= 0 ? '+' : '' %><%= comparacion.diferencia.cantidadVentas %> ventas<br>
                        <%= comparacion.diferencia.cantidadProductos >= 0 ? '+' : '' %><%= comparacion.diferencia.cantidadProductos %> productos
                    </p>
                </div>
            </div>
            
            <div class="section">
                <h3>Resumen Comparativo</h3>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Métrica</th>
                            <th>Período 1</th>
                            <th>Período 2</th>
                            <th>Diferencia</th>
                            <th>% Cambio</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Total Vendido</strong></td>
                            <td>$<%= parseFloat(comparacion.periodo1.totalVendido).toFixed(2) %></td>
                            <td>$<%= parseFloat(comparacion.periodo2.totalVendido).toFixed(2) %></td>
                            <td style="color: <%= comparacion.diferencia.ventas >= 0 ? '#10b981' : '#ef4444' %>;">
                                <%= comparacion.diferencia.ventas >= 0 ? '+' : '' %>$<%= parseFloat(comparacion.diferencia.ventas).toFixed(2) %>
                            </td>
                            <td style="color: <%= comparacion.diferencia.porcentaje >= 0 ? '#10b981' : '#ef4444' %>;">
                                <%= comparacion.diferencia.porcentaje >= 0 ? '+' : '' %><%= comparacion.diferencia.porcentaje %>%
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Cantidad de Ventas</strong></td>
                            <td><%= comparacion.periodo1.cantidadVentas %></td>
                            <td><%= comparacion.periodo2.cantidadVentas %></td>
                            <td style="color: <%= comparacion.diferencia.cantidadVentas >= 0 ? '#10b981' : '#ef4444' %>;">
                                <%= comparacion.diferencia.cantidadVentas >= 0 ? '+' : '' %><%= comparacion.diferencia.cantidadVentas %>
                            </td>
                            <td>-</td>
                        </tr>
                        <tr>
                            <td><strong>Cantidad de Productos</strong></td>
                            <td><%= comparacion.periodo1.cantidadProductos %></td>
                            <td><%= comparacion.periodo2.cantidadProductos %></td>
                            <td style="color: <%= comparacion.diferencia.cantidadProductos >= 0 ? '#10b981' : '#ef4444' %>;">
                                <%= comparacion.diferencia.cantidadProductos >= 0 ? '+' : '' %><%= comparacion.diferencia.cantidadProductos %>
                            </td>
                            <td>-</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <p class="no-data">Selecciona dos períodos para comparar.</p>
        <% } %>
    </main>
    
    <%- include('../partials/help-button') %>
    <%- include('../partials/help-modal') %>
    
    <script src="/js/main.js"></script>
    <script src="/js/help.js"></script>
</body>
</html>

