<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <title>Clientes - El Rincon de Doña Rosa</title>
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/navbar') %>
    
    <main class="container">
        <div class="page-header">
            <h2><i class="fas fa-users"></i> Clientes</h2>
            <a href="/clientes/nuevo" class="btn btn-primary"><i class="fas fa-user-plus"></i> Nuevo Cliente</a>
        </div>
        
        <form method="GET" action="/clientes" class="search-form">
            <input type="text" name="buscar" placeholder="Buscar cliente..." value="<%= termino %>">
            <button type="submit" class="btn btn-secondary"><i class="fas fa-search"></i> Buscar</button>
            <% if (termino) { %>
                <a href="/clientes" class="btn btn-link"><i class="fas fa-times-circle"></i> Limpiar</a>
            <% } %>
        </form>
        
        <% if (clientes && clientes.length > 0) { %>
            <table class="table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th>Fecha de Nacimiento</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% clientes.forEach(cliente => { %>
                        <tr>
                            <td><strong><%= cliente.nombre %></strong></td>
                            <td><%= cliente.telefono || '-' %></td>
                            <td><%= cliente.email || '-' %></td>
                            <td>
                                <% if (cliente.fecha_nacimiento) { %>
                                    <% 
                                    // Parsear fecha manualmente para evitar problemas de zona horaria
                                    const partesFecha = cliente.fecha_nacimiento.split('-');
                                    const diaNac = parseInt(partesFecha[2]);
                                    const mesNac = parseInt(partesFecha[1]);
                                    const anioNac = parseInt(partesFecha[0]);
                                    %>
                                    <%= diaNac %>/<%= mesNac %>/<%= anioNac %>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                            <td class="actions">
                                <a href="/clientes/<%= cliente.id %>" class="btn btn-small btn-primary" title="Ver"><i class="fas fa-eye"></i></a>
                                <a href="/clientes/<%= cliente.id %>/editar" class="btn btn-small btn-secondary" title="Editar"><i class="fas fa-edit"></i></a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <p class="no-data">No se encontraron clientes.</p>
        <% } %>
    </main>
    
    <%- include('../partials/help-button') %>
    <%- include('../partials/help-modal') %>
    
    <script src="/js/main.js"></script>
    <script src="/js/help.js"></script>
</body>
</html>

