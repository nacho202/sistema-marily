<div id="image-cropper-modal" class="modal" style="display:none;">
  <div class="modal-content" style="max-width: 720px;">
    <div class="modal-header">
      <h3>Recortar imagen</h3>
      <button type="button" class="modal-close" id="image-cropper-close">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div class="modal-body">
      <p style="margin-top:0; color:#666;">Ajustá el recorte para que quede cuadrada.</p>
      <div style="max-height: 60vh;">
        <img id="image-cropper-target" alt="Recorte" style="max-width: 100%; display:block;" />
      </div>
      <div class="form-actions" style="margin-top: 1rem;">
        <button type="button" class="btn btn-primary" id="image-cropper-apply">
          <i class="fas fa-crop"></i> Usar recorte
        </button>
        <button type="button" class="btn btn-secondary" id="image-cropper-cancel">
          <i class="fas fa-times"></i> Cancelar
        </button>
      </div>
      <div id="image-cropper-error" class="alert alert-error" style="display:none; margin-top: 0.75rem;"></div>
    </div>
  </div>
</div>

