<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <title>Detalle Compra - El Rincon de Doña Rosa</title>
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/navbar') %>
    
    <main class="container">
        <div class="page-header">
            <h2><i class="fas fa-file-invoice"></i> Detalle de Compra #<%= compra.id %></h2>
        </div>
        
        <div class="detail-section">
            <h3>Información de la Compra</h3>
            <table class="table-detail">
                <tr>
                    <th>Fecha:</th>
                    <td>
                        <% 
                        // Parsear fecha manualmente para evitar problemas de zona horaria
                        const partesFecha = compra.fecha.split(' ')[0].split('-'); // Tomar solo la parte de fecha si hay hora
                        const diaCompra = parseInt(partesFecha[2]);
                        const mesCompra = parseInt(partesFecha[1]);
                        const anioCompra = parseInt(partesFecha[0]);
                        %>
                        <%= diaCompra %>/<%= mesCompra %>/<%= anioCompra %>
                    </td>
                </tr>
                <tr>
                    <th>Proveedor:</th>
                    <td><%= compra.proveedor || '-' %></td>
                </tr>
                <tr>
                    <th>Total:</th>
                    <td>
                        <% if (compra.total) { %>
                            <strong>$<%= parseFloat(compra.total).toFixed(2) %></strong>
                        <% } else { %>
                            -
                        <% } %>
                    </td>
                </tr>
            </table>
        </div>
        
        <div class="detail-section">
            <h3>Productos</h3>
            <table class="table">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Costo Unitario</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    <% compra.detalles.forEach(detalle => { %>
                        <tr>
                            <td><%= detalle.producto_nombre %></td>
                            <td><%= detalle.cantidad %></td>
                            <td>
                                <% if (detalle.costo_unitario) { %>
                                    $<%= parseFloat(detalle.costo_unitario).toFixed(2) %>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                            <td>
                                <% if (detalle.costo_unitario) { %>
                                    $<%= (parseFloat(detalle.cantidad) * parseFloat(detalle.costo_unitario)).toFixed(2) %>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
                <% if (compra.total) { %>
                    <tfoot>
                        <tr>
                            <th colspan="3">Total:</th>
                            <th>$<%= parseFloat(compra.total).toFixed(2) %></th>
                        </tr>
                    </tfoot>
                <% } %>
            </table>
        </div>
        
        <div class="form-actions">
            <a href="/compras" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Volver a Compras</a>
        </div>
    </main>
    
    <%- include('../partials/help-button') %>
    <%- include('../partials/help-modal') %>
    
    <script src="/js/main.js"></script>
    <script src="/js/help.js"></script>
</body>
</html>

