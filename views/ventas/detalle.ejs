<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <title>Detalle Venta - El Rincon de Doña Rosa</title>
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/navbar') %>
    
    <main class="container">
        <div class="page-header">
            <h2><i class="fas fa-receipt"></i> Detalle de Venta #<%= venta.id %></h2>
        </div>
        
        <div class="detail-section">
            <h3>Información de la Venta</h3>
            <table class="table-detail">
                <tr>
                    <th>Fecha:</th>
                    <td><%= new Date(venta.fecha).toLocaleString('es-AR') %></td>
                </tr>
                <tr>
                    <th>Cliente:</th>
                    <td>
                        <% if (venta.cliente_nombre) { %>
                            <a href="/clientes/<%= venta.cliente_id %>"><%= venta.cliente_nombre %></a>
                            <% if (venta.cliente_telefono) { %>
                                <br><small>Tel: <%= venta.cliente_telefono %></small>
                            <% } %>
                            <% if (venta.cliente_email) { %>
                                <br><small>Email: <%= venta.cliente_email %></small>
                            <% } %>
                        <% } else { %>
                            Cliente no registrado
                        <% } %>
                    </td>
                </tr>
                <tr>
                    <th>Total:</th>
                    <td><strong>$<%= parseFloat(venta.total).toFixed(2) %></strong></td>
                </tr>
            </table>
        </div>
        
        <div class="detail-section">
            <h3>Productos</h3>
            <table class="table">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Precio Unitario</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    <% venta.detalles.forEach(detalle => { %>
                        <tr>
                            <td><%= detalle.producto_nombre %></td>
                            <td><%= detalle.cantidad %></td>
                            <td>$<%= parseFloat(detalle.precio_unitario).toFixed(2) %></td>
                            <td>$<%= (parseFloat(detalle.cantidad) * parseFloat(detalle.precio_unitario)).toFixed(2) %></td>
                        </tr>
                    <% }); %>
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="3">Total:</th>
                        <th>$<%= parseFloat(venta.total).toFixed(2) %></th>
                    </tr>
                </tfoot>
            </table>
        </div>
        
        <div class="form-actions">
            <a href="/ventas" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Volver a Ventas</a>
        </div>
    </main>
    
    <%- include('../partials/help-button') %>
    <%- include('../partials/help-modal') %>
    
    <script src="/js/main.js"></script>
    <script src="/js/help.js"></script>
</body>
</html>

